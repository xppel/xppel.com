---
type Props = {
  name: "arrow" | "external" | "southeast" | "broadcast" | "menu" | "close" | "grid" | "list" | "filter";
  title?: string;
};

const { name, title } = Astro.props;
---

<svg class={`icon icon-${name}`} viewBox="0 0 24 24" aria-hidden={title ? "false" : "true"} role={title ? "img" : undefined}>
  {title && <title>{title}</title>}
  {name === "arrow" && <path d="M4 12h14m-5-5 5 5-5 5" />}
  {name === "external" && <path d="M7 17 17 7m-8 0h8v8" />}
  {name === "southeast" && <path d="M7 7 17 17m0-8v8H9" />}
  {name === "broadcast" && (
    <>
      <circle cx="12" cy="12" r="2.2" />
      <path d="M8.4 8.4a5.1 5.1 0 0 0 0 7.2m7.2 0a5.1 5.1 0 0 0 0-7.2M5.3 5.3a9.5 9.5 0 0 0 0 13.4m13.4 0a9.5 9.5 0 0 0 0-13.4" />
    </>
  )}
  {name === "menu" && <path d="M4 7h16M4 12h16M4 17h16" />}
  {name === "close" && <path d="m6 6 12 12M18 6 6 18" />}
  {name === "grid" && (
    <>
      <path d="M5 5h4v4H5zM15 5h4v4h-4zM5 15h4v4H5zM15 15h4v4h-4z" />
    </>
  )}
  {name === "list" && (
    <>
      <path d="M8 6h12M8 12h12M8 18h12M4 6h1M4 12h1M4 18h1" />
    </>
  )}
  {name === "filter" && <path d="M5 7h14M8 12h8M10.5 17h3" />}
</svg>
