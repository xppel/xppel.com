---
import Icon from "./Icon.astro";
import { getImage } from "astro:assets";
import { site } from "../data/site";
import { getProjectGroups, getProjectHref } from "../data/projects";

type Props = {
  activeSlug?: string;
};

const { activeSlug = "" } = Astro.props;
const projectGroups = await getProjectGroups();
const isProjectsIndex = activeSlug === "projects";
const previewModules = import.meta.glob("../content/projects/*/preview.gif", { eager: true });
const normalizePreviewKey = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
const previewGifs = new Map(
  Object.entries(previewModules).map(([path, module]) => {
    const folder = path.split("/").at(-2) ?? "";
    const image = (module as { default: { src: string } }).default;
    return [normalizePreviewKey(folder), image.src] as const;
  })
);
const previewImages = new Map(
  await Promise.all(
    projectGroups.flatMap((group) =>
      group.projects.map(async (project) => {
        const previewGif = previewGifs.get(normalizePreviewKey(project.data.slug));
        if (previewGif) return [project.data.slug, previewGif] as const;
        const image = await getImage({
          src: project.data.thumbnail,
          width: 420,
          height: 280,
          fit: "cover",
          format: "webp"
        });
        return [project.data.slug, image.src] as const;
      })
    )
  )
);
---

<aside class="desktop-nav" aria-label="Primary navigation">
  <div class="brand-field" aria-label="A. Appel">
    <a class="brand-bouncer" href="/" draggable="false" data-brand-bouncer data-home-logo>
      <span>A. Appel <Icon name="broadcast" /></span>
    </a>
  </div>

  <nav class="primary-projects-link" aria-label="Projects index">
    <a class:list={["nav-stable-link", isProjectsIndex && "active"]} href="/projects/" data-nav-label="Projects"><Icon name="arrow" /> <span class="nav-label">Projects</span></a>
  </nav>

  <div class="work-list" aria-label="Project navigation">
    {projectGroups.map((group) => (
      <section class="work-year-group" aria-labelledby={`desktop-year-${group.year}`}>
        <h2 id={`desktop-year-${group.year}`} class="work-year">{group.year}</h2>
        <ul>
          {group.projects.map((project) => (
            <li>
              <a
                class:list={[activeSlug === project.data.slug && "active"]}
                href={getProjectHref(project)}
                data-project-preview
                data-preview-src={previewImages.get(project.data.slug) ?? project.data.thumbnail.src}
                data-preview-title={project.data.title}
              >
                {project.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>

  <nav class="secondary-links" aria-label="Secondary navigation">
    <a class:list={["nav-stable-link", activeSlug === "music" && "active"]} href="/music/" data-nav-label="Music"><Icon name="arrow" /> <span class="nav-label">Music</span></a>
    <a class:list={["nav-stable-link", activeSlug === "photos" && "active"]} href="/photos/" data-nav-label="Photos"><Icon name="arrow" /> <span class="nav-label">Photos</span></a>
    <span class="nav-gap" aria-hidden="true"></span>
    <a class:list={["nav-stable-link", activeSlug === "about" && "active"]} href="/about/" data-nav-label="About"><Icon name="arrow" /> <span class="nav-label">About</span></a>
    <a class="nav-stable-link" href={site.links.email} data-nav-label="Email"><Icon name="external" /> <span class="nav-label">Email</span></a>
  </nav>
  <div class="nav-preview" aria-hidden="true" data-nav-preview>
    <span class="nav-preview-line" aria-hidden="true"></span>
    <span class="nav-preview-frame">
      <img alt="" data-nav-preview-img />
    </span>
  </div>
</aside>

<header class="mobile-header">
  <div class="mobile-topline">
    <a class="mobile-brand" href="/" draggable="false" data-brand-bouncer data-home-logo>
      <span>A. Appel <Icon name="broadcast" /></span>
    </a>
    <button class="menu-button" type="button" aria-controls="mobile-menu" aria-expanded="false" data-menu-toggle>
      <Icon name="menu" title="Open menu" />
    </button>
  </div>
  <nav class="mobile-quick-links" aria-label="Quick links">
    <a class:list={["nav-stable-link", isProjectsIndex && "active"]} href="/projects/" data-nav-label="Projects"><Icon name="arrow" /> <span class="nav-label">Projects</span></a>
    <a class:list={["nav-stable-link", activeSlug === "about" && "active"]} href="/about/" data-nav-label="About"><Icon name="arrow" /> <span class="nav-label">About</span></a>
    <a class="nav-stable-link" href={site.links.email} data-nav-label="Email"><Icon name="external" /> <span class="nav-label">Email</span></a>
  </nav>
</header>

<div class="mobile-menu" id="mobile-menu" hidden>
  <div class="mobile-menu-inner">
    <button class="menu-button close-button" type="button" aria-controls="mobile-menu" aria-expanded="true" data-menu-toggle>
      <Icon name="close" title="Close menu" />
    </button>
    <a class="mobile-menu-brand" href="/" data-home-logo>A. Appel <Icon name="broadcast" /></a>
    <nav class="primary-projects-link" aria-label="Mobile projects index">
      <a class:list={[isProjectsIndex && "active"]} href="/projects/"><Icon name="arrow" /> Projects</a>
    </nav>
    <div class="work-list" aria-label="Mobile project navigation">
      {projectGroups.map((group) => (
        <section class="work-year-group" aria-labelledby={`mobile-year-${group.year}`}>
          <h2 id={`mobile-year-${group.year}`} class="work-year">{group.year}</h2>
          <ul>
            {group.projects.map((project) => (
              <li>
                <a class:list={[activeSlug === project.data.slug && "active"]} href={getProjectHref(project)}>
                  {project.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
    <nav class="secondary-links" aria-label="Mobile secondary navigation">
      <a class:list={[activeSlug === "music" && "active"]} href="/music/"><Icon name="arrow" /> Music</a>
      <a class:list={[activeSlug === "photos" && "active"]} href="/photos/"><Icon name="arrow" /> Photos</a>
      <span class="nav-gap" aria-hidden="true"></span>
      <a class:list={[activeSlug === "about" && "active"]} href="/about/"><Icon name="arrow" /> About</a>
      <a href={site.links.email}><Icon name="external" /> Email</a>
    </nav>
  </div>
</div>
