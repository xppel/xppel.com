---
import Icon from "../components/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="About" activeSlug="about" description="About Andrew Appel.">
  <section class="about-page">
    <header class="two-column about-intro project-rule-grid">
      <div class="project-rule-cell">
        <h1>I’m Andrew, a multimedia<br />designer + engineer + artist.</h1>
      </div>
      <div class="caption about-note project-rule-cell">
        <p>I’m currently based in New York.</p>
        <p>For me, the time is <span data-clock>--:--:-- --</span>.</p>
        <p>Contact information at the links below.</p>
      </div>
    </header>

    <section class="two-column about-copy project-rule-grid">
      <div class="project-rule-cell">
        <p>Thanks for checking out my work.</p>
        <p>Since graduating, I've been teaching myself through personal projects, getting deeper into embedded systems, electronics, UI & UX design, web development, and DSP.</p>
      </div>
      <div class="project-rule-cell">
          <p>Right now I'm building a mix of stuff: hardware music production devices, web and app-based services, sound visualization algorithms, and a few other things I'm excited about.</p>
          <nav class="contact-links" aria-label="Contact links">
            <span class="contact-row">
            <a href={site.links.email}><Icon name="external" /> Email</a>
            <a href={site.links.linkedIn} target="_blank" rel="noopener noreferrer"><Icon name="external" /> LinkedIn</a>
            <a href={site.links.instagram} target="_blank" rel="noopener noreferrer"><Icon name="external" /> Instagram</a>
          </span>
          <span class="contact-row">
            <a href={site.links.resume} target="_blank" rel="noopener noreferrer"><Icon name="southeast" /> Resume / CV</a>
            <a href={site.links.portfolio} target="_blank" rel="noopener noreferrer"><Icon name="southeast" /> Portfolio PDF</a>
          </span>
        </nav>
      </div>
    </section>
  </section>

</BaseLayout>
