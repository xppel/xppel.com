---
import Icon from "../components/Icon.astro";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { getHomeProjects, getProjectHref, getProjects } from "../data/projects";

const projects = getHomeProjects(await getProjects());
---

<BaseLayout title={site.title} activeSlug="home">
  <section class="home-stage" aria-label="Selected work">
    <div class="home-slider is-enhanced" data-home-slider>
      <div class="home-track">
        {projects.map((project, index) => (
          <div class:list={["home-slide", { "is-current": index === 0 }]} data-slide={index} aria-current={index === 0 ? "true" : undefined}>
            <a
              class="home-slide-link"
              href={getProjectHref(project)}
              aria-label={`View ${project.data.title}`}
              style={`--home-slide-aspect: ${project.data.thumbnail.width} / ${project.data.thumbnail.height}; --home-slide-ratio: ${project.data.thumbnail.width / project.data.thumbnail.height};`}
            >
              <Image
                src={project.data.thumbnail}
                alt=""
                widths={[640, 960, 1280, 1600]}
                sizes="(max-width: 760px) 100vw, min(100vw - 27rem, 120rem)"
                loading="eager"
                decoding="async"
                draggable="false"
              />
            </a>
            <span class="home-slide-label">{project.data.title}</span>
          </div>
        ))}
      </div>
      <button class="zone-button zone-prev" type="button" aria-label="Previous project" data-slide-prev>
        <Icon name="arrow" />
      </button>
      <button class="zone-button zone-next" type="button" aria-label="Next project" data-slide-next>
        <Icon name="arrow" />
      </button>
    </div>
  </section>

</BaseLayout>
