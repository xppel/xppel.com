---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getRenderableTracks } from "../data/music";

const trackItems = await getRenderableTracks();
const visibleTracks = trackItems.map((item) => ({
  title: item.track.data.title,
  audio: item.audio,
  Content: item.Content
}));
---

<BaseLayout title="Music" activeSlug="music" description="Music and audio work by Andrew Appel.">
  <section class="music-page">
    <p class="music-intro">
      Here are a few songs I made. They were all made in Ableton Live, and use a mix of recorded instruments, samples, and virtual instruments. I use Max/MSP to make custom effects and synths, and experiment with audio processing.
    </p>

    <ol class="track-list">
      {visibleTracks.map((item, index) => {
        const Content = item.Content;
        return (
          <li>
            <span class="track-heading">{index + 1}.&nbsp; {item.title}</span>
            {Content ? <Content /> : null}
            {item.audio ? (
              <div class="audio-player" data-audio-player>
                <audio preload="metadata" src={item.audio} aria-label={`${item.title} by Andrew Appel`} data-audio></audio>
                <button class="audio-player-button" type="button" aria-label={`Play ${item.title}`} data-audio-toggle>▶</button>
                <div class="audio-player-progress">
                  <input class="audio-player-seek" type="range" min="0" max="1000" value="0" step="1" aria-label={`Seek ${item.title}`} data-audio-seek />
                </div>
                <span class="audio-player-time" data-audio-time>0:00</span>
                <label class="audio-player-volume">
                  <span class="visually-hidden">Volume for {item.title}</span>
                  <span aria-hidden="true">vol</span>
                  <input type="range" min="0" max="1" value="1" step="0.01" data-audio-volume />
                </label>
              </div>
            ) : (
              <div class="audio-placeholder" role="img" aria-label={`${item.title} by Andrew Appel audio placeholder`}>
                <span class="audio-placeholder-button">▶</span>
                <span class="audio-placeholder-track"></span>
                <span class="audio-placeholder-time">--:--</span>
              </div>
            )}
          </li>
        );
      })}
    </ol>

    <p class="music-note">At this time I have not officially released any music.</p>
  </section>

</BaseLayout>
