---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPhotoColumns } from "../data/photos";

const photoColumns = await getPhotoColumns();
let lightboxIndex = 0;
---

<BaseLayout title="Photos" activeSlug="photos" description="Film photography by Andrew Appel.">
  <section class="photos-page">
    <div class="photo-grid">
      {photoColumns.map((column) => (
        <div class="photo-column">
          {column.map((photo, columnItemIndex) => {
            const index = lightboxIndex++;
            return (
              <a href={photo.data.image.src} class="photo-link" aria-label={`Open ${photo.data.title}`} data-lightbox-item data-lightbox-index={index} data-photo-reveal data-photo-reveal-index={index}>
                <Image
                  src={photo.data.image}
                  alt={photo.data.alt ?? photo.data.title}
                  widths={[360, 520, 760, 1080]}
                  sizes="(max-width: 760px) 100vw, 33vw"
                  loading={columnItemIndex === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </a>
            );
          })}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
