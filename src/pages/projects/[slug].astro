---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { site } from "../../data/site";
import { formatTagLabel, getAdjacentProjectsById, getProjectHref, getProjectInfoLines, getProjectTags, getProjects } from "../../data/projects";

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const projects = await getProjects();
const { previousProject, nextProject } = getAdjacentProjectsById(projects, project);
const { Content } = await render(project);
const infoLines = getProjectInfoLines(project);
const tags = getProjectTags(project);
const keywords = tags.map((tag) => tag.label).join(", ");
const frame = project.data.frame;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.data.title,
  description: project.data.subtitle,
  keywords,
  image: project.data.thumbnail.src,
  dateCreated: project.data.completed,
  creator: {
    "@type": "Person",
    name: site.name
  }
};
---

<BaseLayout title={project.data.title} description={`${project.data.title}: ${project.data.subtitle}. ${keywords}`} activeSlug={project.data.slug}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="project-page">
    <header class="project-intro project-rule-grid two-column">
      <div class="project-rule-cell">
        <h1>{project.data.title}</h1>
        <p class="description"><em>{project.data.subtitle}</em></p>
      </div>
      <div class="caption meta-list project-rule-cell">
        {infoLines.map((line) => (
          <p>
            {line.href ? (
              <a class="inline-link" href={line.href} target={line.external ? "_blank" : undefined} rel={line.external ? "noopener noreferrer" : undefined}>{line.text}</a>
            ) : line.text}
          </p>
        ))}
      </div>
    </header>

    <section class="project-body project-rule-grid two-column">
      <div class="project-frame project-rule-cell">
        {frame.type === "image" ? (
          <a class="project-image-link" href={frame.image.src} aria-label={`Open ${project.data.title} image`} data-lightbox-item data-lightbox-index="0">
            {frame.image.src.endsWith(".gif") ? (
              <img class="project-image" src={frame.image.src} alt={frame.alt ?? `${project.data.title} project image`} loading="eager" decoding="async" />
            ) : (
              <Image
                class="project-image"
                src={frame.image}
                alt={frame.alt ?? `${project.data.title} project image`}
                widths={[640, 960, 1280, 1600]}
                sizes="(max-width: 760px) 100vw, 50vw"
                loading="eager"
                decoding="async"
              />
            )}
          </a>
        ) : frame.type === "youtube" ? (
          <iframe
            class="project-embed"
            src={`https://www.youtube-nocookie.com/embed/${frame.videoId}`}
            title={frame.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        ) : (
          <video class="project-image" controls playsinline preload="metadata" poster={frame.poster?.src} aria-label={frame.alt ?? `${project.data.title} project video`}>
            {frame.sources.map((source) => <source src={source.src} type={source.type} />)}
          </video>
        )}
      </div>
      <div class="project-copy project-rule-cell">
        <Content />
        {project.data.portfolioLink && (
          <p>
            More info can be found in{" "}
            <a class="inline-link" href={site.links.portfolio} target="_blank" rel="noopener noreferrer">my portfolio</a>.
          </p>
        )}
      </div>
    </section>

    {tags.length > 0 && (
      <nav class="project-tags" aria-label={`${project.data.title} tags`}>
        {tags.slice(0, 8).map((tag) => (
          <a href={`/projects/?tag=${tag.slug}`} data-tag={tag.slug}>{formatTagLabel(tag.label)}</a>
        ))}
      </nav>
    )}

    <nav class="project-pager" aria-label="Adjacent projects">
      {previousProject ? <a href={getProjectHref(previousProject)} data-project-key-nav="previous">← Previous project</a> : <span></span>}
      {nextProject ? <a href={getProjectHref(nextProject)} data-project-key-nav="next">Next project →</a> : <span></span>}
    </nav>
  </article>
</BaseLayout>
